# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=wfh_attendance
MYSQL_USER=wfh_user
MYSQL_PASSWORD=wfh_password

# Ports
BACKEND_PORT=5000
FRONTEND_PORT=8080

# Node
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-random-secret-string

# URLs (update to https after running setup-ssl.sh)
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:5000

# SMTP is configured via Admin > Settings page (stored in database, not .env)
