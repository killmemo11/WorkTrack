# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=wfh_attendance
MYSQL_USER=wfh_user
MYSQL_PASSWORD=wfh_password

# Ports
BACKEND_PORT=5000
FRONTEND_PORT=8080

# Node
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-random-secret-string

# URLs (update to https after running setup-ssl.sh)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# SMTP for Tenants (configured via Admin > Settings page, stored in database)

# Platform SMTP (for platform admin emails: magic links, tenant approvals, alerts)
# Uses Gmail SMTP by default - configure with App Password
PLATFORM_SMTP_HOST=smtp.gmail.com
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_USER=noreply@worktrack.ddns.net
PLATFORM_SMTP_PASS=your-gmail-app-password
PLATFORM_SMTP_FROM="WorkTrack Platform <noreply@worktrack.ddns.net>"

# Platform Admin Alert Email (receives system alerts)
PLATFORM_ADMIN_ALERT_EMAIL=owner@worktrack.ddns.net

# Platform Super-Admin (created on first seed)
PLATFORM_ADMIN_USERNAME=worktrack_owner
PLATFORM_ADMIN_EMAIL=owner@worktrack.ddns.net
PLATFORM_ADMIN_PASSWORD=  # Leave empty to auto-generate secure password
